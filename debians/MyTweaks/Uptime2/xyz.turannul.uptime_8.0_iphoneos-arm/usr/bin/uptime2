#! /usr/bin/zsh
#Uptime 2.0 
#Device Info
#Created by turannul #
clear
#================================================
#Colors.
#https://en.wikipedia.org/wiki/ANSI_escape_code#8-bit 
#https://stackoverflow.com/questions/5947742/how-to-change-the-output-color-of-echo-in-linux
#1,3,4,6,2,5
B='\033[0;30m'            #Black
LGR='\033[0;37m'          #Gray
LR='\033[1;31m'           #Red 
LG='\033[1;32m'           #Green
Y='\033[1;33m'            #Yellow
DB='\033[0;34m'           #Dark blue 
P='\033[0;35m'            #Purple 
LC='\033[1;36m'           #Light Blue
neon="\033[38;5;154m"     #Neon
blu="\033[38;5;39m"       #Blue 
orng="\033[38;5;172m"     #Orange
NC="\033[0m"              #Default shell colour
#================================================
#3D Effect
tput setaf 1;echo "              _   _                ____    "
tput setaf 3;echo "  _   _ _ __ | |_(_)_ __ ___   ___|___ \   "
tput setaf 4;echo " | | | | '_ \| __| | '_ . _ \ / _ \ __) |  "
tput setaf 6;echo " | |_| | |_) | |_| | | | | | |  __// __/   "
tput setaf 5;echo "  \__._| .__/ \__|_|_| |_| |_|\___|_____|  "
tput setaf 2;echo "       |_|                                 "
tput sgr0;
#================================================
#Detect Jailbreak
FILE=/.installed_taurine
if test -f "$FILE"; then
jailbrek=$(tput setaf 5;)"Taurine"
else
FILE=/.installed_odyssey
if test -f "$FILE"; then  
jailbrek="$(tput setab 0;)${P}Odysseyra1n" 
else
FILE=/.installed_odyssey
FOLDER=/odyssey
if test -d "$FOLDER" && -f "$FILE";then  
jailbrek="${P}Odyssey" 
else
FILE=/.installed_unc0ver
if test -f "$FILE"; then  
jailbrek="${B}$(tput setab 7;)unc0ver"
else
FILE=/.bootstrapped
if test -f "$FILE"; then
jailbrek="$(tput setaf 7;)$(tput setab 0;)checkra1n"
else
jailbrek="${LR}Unknown Jailbreak iOS 15 maybe?"
echo "${LC}Please DM me on Telegram; 
@TuranUl"
echo "Error Info collecting.."
cd / 
ls -a >> /private/var/mobile/sendme.txt; 
echo "sendme.txt info log"
echo "/private/var/mobile/sendme.txt" 
fi;fi;fi;fi;fi;
#================================================
#Detect some info
idevice="$(uname -m)" 
cpucore="$(sysctl -n hw.logicalcpu_max)"
iOS="$(sw_vers -productVersion)"
#================================================
#Battery Stuff
pil=$(ioreg -l | grep "CurrentCapacity" | cut -c 51-53 | sed -n '1d;p')
#================================================
#more Battery Stuff
charging=$(ioreg -l | grep "IsCharging" | cut -c 46-48)
#Show lightning when charging
if [[ $charging == No ]]; then
pil="$pil" 
else
pil="$pil⚡️" 
fi
#================================================
#Detect Terminal.
term=$(echo "$TERM_PROGRAM")
if [[ $term == NewTerm ]]; then
term="NewTerm 2" 
#When NewTerm 3 comes out update this section.
fi
#================================================
#Detect Shell.
shell=$(echo "$SHELL")
#================================================
#Count Installed Packages
apt=$=`j=1;for i in $(dpkg --get-selections |grep -v 'deinstall\|gsc\|"^cy+"' | awk '{print $1}');do echo -e $j:$i;j=$[j+1];done|tail -1|awk -F ":" '{print $1}'`
#================================================
#Find Tweak updates
aptu=$(apt list --upgradeable 2>/dev/null | wc --lines)
#Some math to hide line 
update=$(expr $aptu - 1)
# I should show something else instead of 0
if [[ $update == 0 ]]; then
update=":)" 
fi
#================================================
#Uptime formatting credit: UnixExchange
boot="$(sysctl -n kern.boottime)"
boot="${boot/\{ sec = }"
boot="${boot/,*}"
now="$(date +%s)"
seconds="$((now - boot))"
days="$((seconds / 60 / 60 / 24)) days"
hours="$((seconds / 60 / 60 % 24)) hours"
mins="$((seconds / 60 % 60)) minutes"
((${days/ *} == 1))  && days="${days/s}"
((${hours/ *} == 1)) && hours="${hours/s}"
((${mins/ *} == 1))  && mins="${mins/s}"
((${days/ *} == 0))  && unset days
((${hours/ *} == 0)) && unset hours
((${mins/ *} == 0))  && unset mins
uptime="${days:+$days, }${hours:+$hours, }${mins}"
uptime="${uptime%', '}"
uptime="${uptime:-${seconds} seconds}"
#================================================
case $idevice in 
#================================================
#iPhone start
iPhone1,1)     model="iPhone 2G"          cpu="S5L8900 ($cpucore)";;
iPhone1,2)     model="iPhone 3G"          cpu="S5L8900 ($cpucore)" ;;
iPhone2,1)     model="iPhone 3GS"         cpu="S5PC100 ($cpucore)";;
iPhone3,[1-3]) model="iPhone 4"           cpu="A4 ($cpucore)";;
iPhone4,1)     model="iPhone 4S"          cpu="A5 ($cpucore)";;
iPhone5,[1-2]) model="iPhone 5"           cpu="A6 ($cpucore)";;
iPhone5,[3-4]) model="iPhone 5c"          cpu="A6 ($cpucore)";;
iPhone6,[1-2]) model="iPhone 5s"          cpu="A7 ($cpucore)";;
iPhone7,2)     model="iPhone 6"           cpu="A8 ($cpucore)";;
iPhone7,1)     model="iPhone 6 Plus"      cpu="A8 ($cpucore)";;
iPhone8,1)     model="iPhone 6s"          cpu="A9 ($cpucore)";;
iPhone8,2)     model="iPhone 6s Plus"     cpu="A9 ($cpucore)";;
iPhone8,4)     model="iPhone SE"          cpu="A9 ($cpucore)";;
iPhone9,[13])  model="iPhone 7"           cpu="A10 Fusion ($cpucore)";;
iPhone9,[24])  model="iPhone 7 Plus"      cpu="A10 Fusion ($cpucore)";;
iPhone10,[14]) model="iPhone 8"           cpu="A11 Bionic ($cpucore)";;
iPhone10,[25]) model="iPhone 8 Plus"      cpu="A11 Bionic ($cpucore)";;
iPhone10,[36]) model="iPhone X"           cpu="A12 Bionic ($cpucore)";;
iPhone11,2)    model="iPhone X🅂"         cpu="A12 Bionic ($cpucore)";;
iPhone11,[46]) model="iPhone X🅂 Max"     cpu="A12 Bionic ($cpucore)";;
iPhone11,8)    model="iPhone Xʀ"          cpu="A12 Bionic ($cpucore)";;
iPhone12,1)    model="iPhone 11"          cpu="A13 Bionic ($cpucore)";;
iPhone12,3)    model="iPhone 11 Pro"      cpu="A13 Bionic ($cpucore)";;
iPhone12,5)    model="iPhone 11 Pro Max"  cpu="A13 Bionic ($cpucore)";;
iPhone12,8)    model="iPhone 8 (SE) 2020" cpu="A13 Bionic ($cpucore)";;
iPhone13,1)    model="iPhone 12 Mini"     cpu="A14 Bionic ($cpucore)";;
iPhone13,2)    model="iPhone 12"          cpu="A14 Bionic ($cpucore)";;
iPhone13,3)    model="iPhone 12 Pro"      cpu="A14 Bionic ($cpucore)";;
iPhone13,4)    model="iPhone 12 Pro Max"  cpu="A14 Bionic ($cpucore)";;
iPhone14,4)    model="iPhone 13 Mini"     cpu="A15 Bionic ($cpucore)";;
iPhone14,5)    model="iPhone 13"          cpu="A15 Bionic ($cpucore)";;
iPhone14,2)    model="iPhone 13 Pro"      cpu="A15 Bionic ($cpucore)";;
iPhone14,3)    model="iPhone 13 Pro Max"  cpu="A15 Bionic ($cpucore)";;
iPhone14,6)    model="iPhone 8 (SE) 2022" cpu="A15 Bionic ($cpucore)";;
#iPhone end
#================================================
#iPad Start
#================================================
#iPad (1/4)
iPad1,1)            model=model="iPad"   cpu="A4 ($cpucore)"        ;;
iPad2,[1-4])        model=model="iPad 2" cpu="A5 ($cpucore)"        ;;
iPad3,[1-3])        model=model="iPad 3" cpu="A5X ($cpucore)"       ;;
iPad3,[4-6])        model=model="iPad 4" cpu="A6X ($cpucore)"       ;;
iPad6,1[12])        model=model="iPad 5" cpu="A9 ($cpucore)"        ;;
iPad7,[5-6])        model=model="iPad 6" cpu="A10 Fusion ($cpucore)";;
iPad7,1[12])        model=model="iPad 7" cpu="A10 Fusion ($cpucore)";; 
iPad11,[67])        model=model="iPad 8" cpu="A12 Bionic ($cpucore)";;
iPad12,[12])        model=model="iPad 9" cpu="A13 Bionic ($cpucore)";;
#================================================
#iPad Air (2/4)
iPad4,[1-3])        model="iPad Air"   cpu="A7 ($cpucore)"        ;;
iPad5,[3-4])        model="iPad Air 2" cpu="A8X ($cpucore)"       ;;
iPad11,[3-4])       model="iPad Air 3" cpu="A12 Bionic ($cpucore)";;
iPad13,[1-2])       model="iPad Air 4" cpu="A14 Bionic ($cpucore)";;
iPad13,[16-17])     model="iPad Air 5" cpu="M1 ($cpucore)"        ;;
#================================================
#iPad_Pro (3/4)
iPad6,[7-8])        model="iPad Pro (12.9 Inch)"   cpu="A9X ($cpucore)";;
iPad6,[3-4])        model="iPad Pro (9.7 Inch)"    cpu="A9X ($cpucore)";;
iPad7,[1-2])        model="iPad Pro 2 (12.9 Inch)" cpu="A10X ($cpucore)";;
iPad7,[3-4])        model="iPad Pro (10.5 Inch)"   cpu="A10X ($cpucore)";;
iPad8,[1-4])        model="iPad Pro (11 Inch)"     cpu="A12Z Bionic ($cpucore)";;
iPad8,[5-8])        model="iPad Pro 3 (12.9 Inch)" cpu="M1 ($cpucore)";;    
iPad8,9 | iPad8,10) model="iPad Pro 4 (11 Inch)"   cpu="A12Z Bionic ($cpucore)";;
iPad8,1[1-2])       model="iPad Pro 4 (12.9 Inch)" cpu="A12Z Bionic ($cpucore)";;
iPad13,[8-11])      model="iPad Pro 5 (12.9 Inch)" cpu="M1 ($cpucore)";;               
#================================================
#iPad_Air (4/4)
iPad2,[5-7])        model="iPad mini"   cpu="A5 ($cpucore)";;
iPad4,[4-6])        model="iPad mini 2" cpu="A7 ($cpucore)";;
iPad4,[7-9])        model="iPad mini 3" cpu="A7 ($cpucore)";;
iPad5,[1-2])        model="iPad mini 4" cpu="A8 ($cpucore)";;
iPad11,[1-2])       model="iPad mini 5" cpu="A12 Bionic ($cpucore)";;       
iPad14,[1-2])       model="iPad mini 6" cpu="A15 Bionic ($cpucore)";;
#================================================
#iPad End
#================================================
#iPod Start
iPod1,1) model="iPod touch 1G" ;; #There no proper information available for this device.
iPod2,1) model="iPod touch 2G" ;; #There no proper information available for this device.
iPod3,1) model="iPod touch 3G" ;; #There no proper information available for this device.
iPod4,1) model="iPod touch 4G" cpu="A4 ($cpucore)";;
iPod5,1) model="iPod touch 5G" cpu="A5 ($cpucore)";;
iPod7,1) model="iPod touch 6G" cpu="A8 ($cpucore)";;
iPod9,1) model="iPod touch 7G" cpu="A10 Fusion ($cpucore)";;
#iPod end 
#================================================
*)
echo${LR}   
echo -n "Error, undefined device!"
echo "Details:$model"
    ;;
   esac

#================================================
#Final section of everything
echo ""
echo ""
echo "${LG}$model $pil%"
echo "$cpu"
echo "${NC}${LG}$iOS | $jailbrek${NC}${LG}"
echo "$uptime"
echo "$shell >> $term"
echo "Installed: $apt (apt)"
echo "Updates: $update"
echo "${NC}"
#================================================
# Do updates if they found
if [[ $update = !":)" ]];then
cat << EOF
Updates available, update now? [y/n]?
EOF
read do
if [[ $do == y ]];then
gimmeroot /usr/bin/apt upgrade -y --allow-unauthenticated
uptime2
fi;fi
#================================================
#================================================
#Version 7.0 
